# See https://help.github.com/articles/ignoring-files for more about ignoring files.

# OS files
.DS_Store
Thumbs.db

# Editor / IDE
*.swp
*.swo
*~
.idea/
.vscode/

# Bundler
/.bundle

# Environment files
/.env*

# Logs and temp files
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Pidfiles
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Storage (uploaded files in development and any SQLite databases)
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

# SQLite databases (used for cache, queue, cable)
*.sqlite3
*.sqlite3-journal
*.sqlite3-shm
*.sqlite3-wal

# Compiled assets
/public/assets

# Credential keys
/config/*.key

# Vite Ruby
/public/vite*
node_modules

# Vite uses dotenv and suggests to ignore local-only env files.
# https://vitejs.dev/guide/env-and-mode.html#env-files
*.local

# Orientation detection service
services/orientation/.venv/
services/orientation/__pycache__/
services/orientation/models/*.onnx
