<%= simple_form_for event do |f| %>
  <div class="row">
    <div class="col-md-6">
      <div class="mb-3">
        <%= f.input :title, input_html: { class: 'form-control' }, label_html: { class: 'form-label' } %>
      </div>
      <div class="mb-3">
        <%= f.input :description, as: :text, input_html: { class: 'form-control', rows: 4 }, label_html: { class: 'form-label' } %>
      </div>
      <div class="mb-3">
        <%= render 'shared/location_autocomplete', field_name: 'event[location_id]', label: 'Location', current_location: event.location, placeholder: 'Search for a location...' %>
      </div>
    </div>
    <div class="col-md-6">
      <fieldset class="form-fieldset">
        <legend>Date Range</legend>
        <div class="mb-3">
          <%= f.input :date_type, collection: ['exact', 'year_month', 'year', 'season', 'decade'], input_html: { class: 'form-select' }, label_html: { class: 'form-label' } %>
        </div>
        <h4 class="mb-2">From</h4>
        <div class="row mb-3">
          <div class="col-4">
            <%= f.input :year_from, input_html: { class: 'form-control' }, label_html: { class: 'form-label' } %>
          </div>
          <div class="col-4">
            <%= f.input :month_from, input_html: { class: 'form-control' }, label_html: { class: 'form-label' } %>
          </div>
          <div class="col-4">
            <%= f.input :day_from, input_html: { class: 'form-control' }, label_html: { class: 'form-label' } %>
          </div>
        </div>
        <div class="row mb-3">
          <div class="col-6">
            <%= f.input :season_from, collection: ['Spring', 'Summer', 'Autumn', 'Winter'], input_html: { class: 'form-select' }, label_html: { class: 'form-label' } %>
          </div>
          <div class="col-6 d-flex align-items-end pb-2">
            <%= f.input :circa_from, as: :boolean, wrapper_html: { class: 'form-check' }, input_html: { class: 'form-check-input' }, label_html: { class: 'form-check-label' } %>
          </div>
        </div>
        <h4 class="mb-2">To (Optional)</h4>
        <div class="row mb-3">
          <div class="col-4">
            <%= f.input :year_to, input_html: { class: 'form-control' }, label_html: { class: 'form-label' } %>
          </div>
          <div class="col-4">
            <%= f.input :month_to, input_html: { class: 'form-control' }, label_html: { class: 'form-label' } %>
          </div>
          <div class="col-4">
            <%= f.input :day_to, input_html: { class: 'form-control' }, label_html: { class: 'form-label' } %>
          </div>
        </div>
        <div class="row mb-3">
          <div class="col-6">
            <%= f.input :season_to, collection: ['Spring', 'Summer', 'Autumn', 'Winter'], input_html: { class: 'form-select' }, label_html: { class: 'form-label' } %>
          </div>
          <div class="col-6 d-flex align-items-end pb-2">
            <%= f.input :circa_to, as: :boolean, wrapper_html: { class: 'form-check' }, input_html: { class: 'form-check-input' }, label_html: { class: 'form-check-label' } %>
          </div>
        </div>
      </fieldset>
    </div>
  </div>
  <div class="form-footer mt-4">
    <%= link_to "Cancel", events_path, class: "btn btn-link" %>
    <%= f.button :submit, class: "btn btn-primary" %>
  </div>
<% end %>
