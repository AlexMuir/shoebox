<% content_for(:page_title, "Events") %>
<% content_for(:page_actions) do %>
  <div class="btn-list">
    <%= link_to new_event_path, class: "btn btn-primary d-none d-sm-inline-block" do %>
      <i class="ti ti-plus icon"></i>
      New Event
    <% end %>
  </div>
<% end %>
<div class="row row-cards">
  <% @events.each do |event| %>
    <div class="col-md-6 col-lg-4">
      <div class="card">
        <div class="card-body">
          <h3 class="card-title"><%= link_to event.title, event_path(event), class: "text-body" %></h3>
          <div class="text-secondary mb-3">
            <div class="mb-1">
              <i class="ti ti-calendar icon me-2"></i>
              <%= event.date_range_display.presence || "Unknown date" %>
            </div>
            <% if event.location %>
              <div>
                <i class="ti ti-map-pin icon me-2"></i>
                <%= event.location.name %>
              </div>
            <% end %>
          </div>
          <div class="d-flex align-items-center">
            <span class="badge bg-primary-lt"><%= event.photos.count %> photos</span>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>
