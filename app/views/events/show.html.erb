<% content_for(:page_title, @event.title) %>
<% content_for(:page_actions) do %>
  <div class="btn-list">
    <%= link_to edit_event_path(@event), class: "btn btn-primary" do %>
      <i class="ti ti-edit icon"></i>
      Edit Event
    <% end %>
  </div>
<% end %>
<div class="row row-cards">
  <div class="col-lg-4">
    <div class="card">
      <div class="card-body">
        <h3 class="card-title">Event Details</h3>
        <div class="mb-3">
          <strong>Date:</strong><br>
          <%= @event.date_range_display.presence || "Unknown" %>
        </div>
        <% if @event.location %>
          <div class="mb-3">
            <strong>Location:</strong><br>
            <%= link_to @event.location.name, location_path(@event.location) %>
          </div>
        <% end %>
        <% if @event.description.present? %>
          <div>
            <strong>Description:</strong><br>
            <%= simple_format(@event.description) %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
  <div class="col-lg-8">
    <div class="card">
      <div class="card-header">
        <h3 class="card-title">Photos (<%= @event.photos.count %>)</h3>
      </div>
      <div class="card-body">
        <div class="row row-cards">
          <% @event.photos.each do |photo| %>
            <div class="col-sm-6 col-md-4">
              <div class="card card-sm">
                <%= link_to photo_path(photo), class: "d-block" do %>
                  <% if photo.original.attached? %>
                    <%= image_tag photo.display_image.variant(:thumb), class: "card-img-top", style: "aspect-ratio: 1/1; object-fit: cover;" %>
                  <% else %>
                    <div class="card-img-top bg-secondary-lt d-flex align-items-center justify-content-center" style="aspect-ratio: 1/1;">
                      <i class="ti ti-photo text-secondary" style="font-size: 3rem;"></i>
                    </div>
                  <% end %>
                <% end %>
                <div class="card-body">
                  <div class="d-flex align-items-center">
                    <div>
                      <div class="text-truncate" style="max-width: 150px;" title="<%= photo.display_title %>">
                        <%= link_to photo.display_title, photo_path(photo), class: "text-body fw-bold" %>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
          <% if @event.photos.empty? %>
            <div class="col-12 text-center py-5 text-secondary">
              <i class="ti ti-photo-off mb-3" style="font-size: 3rem;"></i>
              <p>No photos for this event yet.</p>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
