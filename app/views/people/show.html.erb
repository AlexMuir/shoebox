<% content_for(:page_title, @person.full_name) %>
<% content_for(:page_actions) do %>
  <div class="btn-list">
    <%= link_to edit_person_path(@person), class: "btn btn-primary" do %>
      <i class="ti ti-edit icon"></i>
      Edit Person
    <% end %>
  </div>
<% end %>
<div class="row row-cards">
  <div class="col-lg-4">
    <div class="card">
      <div class="card-body text-center">
        <span class="avatar avatar-xl mb-3 bg-primary-lt"><%= @person.full_name.first(2).upcase %></span>
        <h3 class="m-0 mb-1"><%= @person.full_name %></h3>
        <% if @person.maiden_name.present? %>
          <div class="text-secondary mb-3">née <%= @person.maiden_name %></div>
        <% end %>
        <div class="mt-3">
        <% if @person.date_of_birth.present? || @person.date_of_death.present? || @person.dob_text.present? %>
            <div class="mb-2">
              <i class="ti ti-calendar icon me-2 text-secondary"></i>
              <% if @person.date_of_birth.present? %>
                <%= @person.date_of_birth&.to_fs(:long) %> - <%= @person.date_of_death&.to_fs(:long) || "Present" %>
              <% elsif @person.dob_text.present? %>
                <%= @person.dob_text %>
              <% else %>
                ? - <%= @person.date_of_death&.to_fs(:long) || "Present" %>
              <% end %>
            </div>
            <% if @person.age %>
              <div class="mb-2">
                <i class="ti ti-user icon me-2 text-secondary"></i>
                <%= @person.age %> years old
              </div>
            <% end %>
          <% end %>
        </div>
      </div>
      <% if @person.bio.present? %>
        <div class="card-body border-top">
          <h4 class="card-title">Biography</h4>
          <p class="mb-0"><%= simple_format(@person.bio) %></p>
        </div>
      <% end %>
    </div>
  </div>
  <div class="col-lg-8">
    <div class="card">
      <div class="card-header">
        <h3 class="card-title">Photos (<%= @person.photos.count %>)</h3>
      </div>
      <div class="card-body">
        <div class="row row-cards">
          <% @person.photos.each do |photo| %>
            <div class="col-sm-6 col-md-4">
              <div class="card card-sm">
                <%= link_to photo_path(photo), class: "d-block" do %>
                  <% if photo.original.attached? %>
                    <%= image_tag photo.oriented_variant(:thumb), class: "card-img-top", style: "aspect-ratio: 1/1; object-fit: cover;" %>
                  <% else %>
                    <div class="card-img-top bg-secondary-lt d-flex align-items-center justify-content-center" style="aspect-ratio: 1/1;">
                      <i class="ti ti-photo text-secondary" style="font-size: 3rem;"></i>
                    </div>
                  <% end %>
                <% end %>
                <div class="card-body">
                  <div class="d-flex align-items-center">
                    <div>
                      <div class="text-truncate" style="max-width: 150px;" title="<%= photo.display_title %>">
                        <%= link_to photo.display_title, photo_path(photo), class: "text-body fw-bold" %>
                      </div>
                      <div class="text-secondary text-truncate" style="max-width: 150px;">
                        <%= photo.date_text %>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
          <% if @person.photos.empty? %>
            <div class="col-12 text-center py-5 text-secondary">
              <i class="ti ti-photo-off mb-3" style="font-size: 3rem;"></i>
              <p>No photos tagged with this person yet.</p>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
