<% content_for(:page_title, "Enter Login Code") %>
<div class="container-tight py-4">
  <div class="card card-md">
    <div class="card-body">
      <h2 class="h2 text-center mb-4">Enter Login Code</h2>
      <p class="text-secondary mb-4 text-center">We've sent a 6-digit code to your email.</p>
      <% if Rails.env.development? && flash[:login_code].present? %>
        <div class="alert alert-info" role="alert">
          <div class="d-flex">
            <div>
              <i class="ti ti-info-circle icon alert-icon"></i>
            </div>
            <div>
              <h4 class="alert-title">Development Mode</h4>
              <div class="text-secondary">Your login code is: <strong><%= flash[:login_code] %></strong></div>
            </div>
          </div>
        </div>
      <% end %>
      <%= simple_form_for :login_code, url: session_login_code_path do |f| %>
        <div class="mb-3">
          <%= f.input :code, 
                      required: true, 
                      autofocus: true, 
                      input_html: { class: 'form-control', placeholder: '123456', autocomplete: 'one-time-code' },
                      label_html: { class: 'form-label' } %>
        </div>
        <div class="form-footer">
          <%= f.button :submit, "Verify Code", class: "btn btn-primary w-100" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
