<% content_for(:page_title, "Sign In") %>
<div class="container-tight py-4">
  <div class="card card-md">
    <div class="card-body">
      <h2 class="h2 text-center mb-4">Login to your account</h2>
      <%= simple_form_for :session, url: session_path do |f| %>
        <div class="mb-3">
          <%= f.input :email, 
                      required: true, 
                      autofocus: true, 
                      input_html: { class: 'form-control', placeholder: 'your@email.com' },
                      label_html: { class: 'form-label' } %>
        </div>
        <div class="form-footer">
          <%= f.button :submit, "Send Login Code", class: "btn btn-primary w-100" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
