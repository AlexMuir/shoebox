<% content_for(:page_title, "Dashboard") %>
<div class="row row-deck row-cards mb-4">
  <div class="col-sm-6 col-lg-4">
    <div class="card">
      <div class="card-body">
        <div class="d-flex align-items-center">
          <div class="subheader">Photos</div>
        </div>
        <div class="h1 mb-3"><%= @photos_count %></div>
        <div class="d-flex mb-2">
          <div>Total photos in library</div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-lg-4">
    <div class="card">
      <div class="card-body">
        <div class="d-flex align-items-center">
          <div class="subheader">People</div>
        </div>
        <div class="h1 mb-3"><%= @people_count %></div>
        <div class="d-flex mb-2">
          <div>Tagged people</div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-lg-4">
    <div class="card">
      <div class="card-body">
        <div class="d-flex align-items-center">
          <div class="subheader">Events</div>
        </div>
        <div class="h1 mb-3"><%= @events_count %></div>
        <div class="d-flex mb-2">
          <div>Documented events</div>
        </div>
      </div>
    </div>
  </div>
</div>
<div class="row row-cards mb-4">
  <div class="col-12">
    <div class="card">
      <div class="card-header">
        <h3 class="card-title">Recent Photos</h3>
        <div class="card-actions">
          <%= link_to "View all", photos_path, class: "btn btn-sm btn-primary" %>
        </div>
      </div>
      <div class="card-body">
        <div class="row row-cards">
          <% @recent_photos.each do |photo| %>
            <div class="col-sm-6 col-lg-3">
              <div class="card card-sm">
                <%= link_to photo_path(photo), class: "d-block" do %>
                  <% if photo.original.attached? %>
                    <%= image_tag photo.oriented_variant(:thumb), class: "card-img-top", style: "aspect-ratio: 1/1; object-fit: cover;" %>
                  <% else %>
                    <div class="card-img-top bg-secondary-lt d-flex align-items-center justify-content-center" style="aspect-ratio: 1/1;">
                      <i class="ti ti-photo text-secondary" style="font-size: 3rem;"></i>
                    </div>
                  <% end %>
                <% end %>
                <div class="card-body">
                  <div class="d-flex align-items-center">
                    <div>
                      <div><%= link_to photo.display_title, photo_path(photo), class: "text-body" %></div>
                      <div class="text-secondary"><%= photo.date_text %></div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
<div class="row row-cards">
  <div class="col-12">
    <div class="card">
      <div class="card-header">
        <h3 class="card-title">Recent Uploads</h3>
        <div class="card-actions">
          <%= link_to "View all", uploads_path, class: "btn btn-sm btn-primary" %>
        </div>
      </div>
      <div class="table-responsive">
        <table class="table card-table table-vcenter text-nowrap datatable">
          <thead>
            <tr>
              <th>Source Album</th>
              <th>Owner</th>
              <th>Date Range</th>
              <th>Photos</th>
              <th>Status</th>
              <th>Date</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% @recent_uploads.each do |upload| %>
              <tr>
                <td><%= link_to upload.source_album.presence || "Untitled", upload_path(upload) %></td>
                <td><%= upload.source_owner %></td>
                <td><%= upload.date_range_display %></td>
                <td><%= upload.photos_count %></td>
                <td>
                  <span class="badge bg-<%= upload.status == 'completed' ? 'success' : 'warning' %> me-1"></span>
                  <%= upload.status.titleize %>
                </td>
                <td><%= upload.created_at.to_date.to_fs(:short) %></td>
                <td class="text-end">
                  <%= link_to "View", upload_path(upload), class: "btn btn-sm" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
