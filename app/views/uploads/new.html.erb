<% content_for(:page_title, "Batch Upload Photos") %>
<div class="row row-cards">
  <div class="col-12">
    <div class="card">
      <div class="card-body">
        <%= simple_form_for @upload, html: { multipart: true } do |f| %>
          <div class="row">
            <div class="col-md-12 mb-4">
              <fieldset class="form-fieldset bg-primary-lt border-primary">
                <legend class="text-primary fw-bold"><i class="ti ti-upload me-2"></i>Select Photos</legend>
                <div class="mb-3" data-controller="file-timestamps">
                  <%= f.input :files, as: :file, input_html: { multiple: true, class: 'form-control form-control-lg', accept: 'image/*', data: { file_timestamps_target: 'input', action: 'change->file-timestamps#capture' } }, label: "Choose files to upload", label_html: { class: 'form-label fw-bold' } %>
                  <small class="form-hint mt-2">You can select multiple files at once. They will all be tagged with the source information below.</small>
                </div>
              </fieldset>
            </div>
            <div class="col-md-6">
              <fieldset class="form-fieldset">
                <legend>Source Context</legend>
                <p class="text-secondary mb-3">Where did these photos come from?</p>
                <div class="mb-3">
                  <%= f.input :source_album, label: "Album / Box Name", input_html: { class: 'form-control', placeholder: "e.g. 'Red Photo Album' or 'Shoebox 1'" }, label_html: { class: 'form-label' } %>
                </div>
                <div class="mb-3">
                  <%= render "shared/person_autocomplete",
                    field_name: "upload[source_owner_id]",
                    label: "Original Owner",
                    current_person: @upload.source_owner,
                    placeholder: "e.g. 'Grandma Smith'" %>
                </div>
                <div class="mb-3">
                  <%= render "shared/person_autocomplete",
                    field_name: "upload[scanned_by_person_id]",
                    label: "Scanned by",
                    current_person: @upload.scanned_by_person,
                    placeholder: "Who scanned these photos?" %>
                </div>
              </fieldset>
            </div>
            <div class="col-md-6">
              <fieldset class="form-fieldset">
                <legend>Additional Details</legend>
                <div class="row mb-3">
                  <div class="col-6">
                    <%= f.input :year_from, label: "Earliest Year", input_html: { class: 'form-control', placeholder: "YYYY" }, label_html: { class: 'form-label' } %>
                  </div>
                  <div class="col-6">
                    <%= f.input :year_to, label: "Latest Year", input_html: { class: 'form-control', placeholder: "YYYY" }, label_html: { class: 'form-label' } %>
                  </div>
                </div>
                <div class="mb-3">
                  <%= f.input :notes, as: :text, input_html: { class: 'form-control', rows: 4, placeholder: "Any context about this batch of photos..." }, label_html: { class: 'form-label' } %>
                </div>
              </fieldset>
            </div>
          </div>
          <div class="form-footer mt-4">
            <%= link_to "Cancel", uploads_path, class: "btn btn-link" %>
            <%= f.button :submit, "Upload Photos", class: "btn btn-primary btn-lg" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
