<% content_for(:page_title, @upload.source_album.presence || "Upload Batch") %>
<% content_for(:page_actions) do %>
  <div class="btn-list">
    <%= link_to edit_upload_path(@upload), class: "btn btn-primary" do %>
      <i class="ti ti-edit icon"></i>
      Edit Details
    <% end %>
  </div>
<% end %>
<div class="row row-cards">
  <div class="col-lg-4">
    <div class="card">
      <div class="card-body">
        <h3 class="card-title">Source Information</h3>
        <dl class="row mb-0">
          <dt class="col-5">Album/Box:</dt>
          <dd class="col-7"><%= @upload.source_album.presence || "Unknown" %></dd>
          <dt class="col-5">Owner:</dt>
          <dd class="col-7"><%= @upload.source_owner&.full_name.presence || "Unknown" %></dd>
          <dt class="col-5">Date Range:</dt>
          <dd class="col-7"><%= @upload.date_range_display.presence || "Unknown" %></dd>
          <dt class="col-5">Scanned By:</dt>
          <dd class="col-7"><%= @upload.scanned_by_person&.full_name.presence || "Unknown" %></dd>
          <dt class="col-5">Uploaded By:</dt>
          <dd class="col-7"><%= @upload.user&.email %></dd>
          <dt class="col-5">Status:</dt>
          <dd class="col-7">
            <span class="badge bg-<%= @upload.status == 'completed' ? 'success' : 'warning' %> me-1"></span>
            <%= @upload.status.titleize %>
          </dd>
        </dl>
      </div>
      <% if @upload.notes.present? %>
        <div class="card-body border-top">
          <h4 class="card-title">Notes</h4>
          <p class="mb-0"><%= simple_format(@upload.notes) %></p>
        </div>
      <% end %>
    </div>
  </div>
  <div class="col-lg-8">
    <div class="card">
      <div class="card-header">
        <h3 class="card-title">Photos in this batch (<%= @upload.photos.count %>)</h3>
      </div>
      <div class="card-body">
        <div class="row row-cards">
          <% @upload.photos.each do |photo| %>
            <div class="col-sm-6 col-md-4">
              <div class="card card-sm">
                <%= link_to photo_path(photo), class: "d-block" do %>
                  <% if photo.image.attached? %>
                    <%= image_tag photo.image.variant(:thumb), class: "card-img-top", style: "aspect-ratio: 1/1; object-fit: cover;" %>
                  <% else %>
                    <div class="card-img-top bg-secondary-lt d-flex align-items-center justify-content-center" style="aspect-ratio: 1/1;">
                      <i class="ti ti-photo text-secondary" style="font-size: 3rem;"></i>
                    </div>
                  <% end %>
                <% end %>
                <div class="card-body">
                  <div class="d-flex align-items-center">
                    <div>
                      <div class="text-truncate" style="max-width: 150px;" title="<%= photo.display_title %>">
                        <%= link_to photo.display_title, photo_path(photo), class: "text-body fw-bold" %>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
          <% if @upload.photos.empty? %>
            <div class="col-12 text-center py-5 text-secondary">
              <i class="ti ti-photo-off mb-3" style="font-size: 3rem;"></i>
              <p>No photos in this batch yet.</p>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
